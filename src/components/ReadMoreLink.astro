---
import { Post } from '../lib/interfaces.ts'
import { getPostLink } from '../lib/blog-helpers.ts'

export interface Props {
  post: Post
}

const { post } = Astro.props
---

<div class="tobiracast-text-center tobiracast-mt-6">
  <a href={getPostLink(post.Slug)} class="tobiracast-btn tobiracast-btn-secondary">続きを読む →</a>
</div>

<!-- ReadMore button now uses unified tobiracast-btn styles -->
