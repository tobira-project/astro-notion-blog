---
import PostCard from './PostCard.astro'

export interface Props {
  post: any
  index?: number
  layout?: 'grid' | 'list'
}

const { post, index = 0, layout = 'grid' } = Astro.props
---

<a 
  href={`/posts/${post.Slug}`}
  class="block bg-white rounded-xl shadow-lg overflow-hidden transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 opacity-0 animate-[fadeInUp_0.8s_ease-out_forwards]"
  style={`animation-delay: ${index * 0.1}s`}
>
  {layout === 'list' ? (
    <div class="md:flex w-full">
      <div class="md:w-1/3">
        <div class="h-64 md:h-full">
          <PostCard post={post} showExcerpt={false} showTags={false} />
        </div>
      </div>
      <div class="md:w-2/3 p-8">
        <PostCard post={post} showImage={false} />
        <div class="mt-4">
          <span class="text-blue-600 font-semibold hover:text-blue-700">
            続きを読む →
          </span>
        </div>
      </div>
    </div>
  ) : (
    <>
      <PostCard post={post} className="p-6" />
      <div class="px-6 pb-6">
        <span class="text-blue-600 font-semibold hover:text-blue-700">
          続きを読む →
        </span>
      </div>
    </>
  )}
</a>