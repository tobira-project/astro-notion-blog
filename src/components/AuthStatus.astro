---
import { getNavLink } from '../lib/blog-helpers.ts'
// このコンポーネントはクライアントサイドでログイン状態を管理します
---

<div id="auth-status-loading" class="auth-link auth-link-loading" aria-hidden="true">
  読み込み中
</div>

<!-- ログイン前の表示 -->
<a href={getNavLink('/login')} id="logged-out-nav" class="auth-link" hidden>ログイン</a>

<!-- ログイン後の表示 -->
<a href={getNavLink('/mypage')} id="logged-in-nav" class="auth-link" hidden>マイページ</a>

<style>
  .auth-link {
    display: block;
    padding: 16px 32px;
    color: var(--tobiracast-primary-orange);
    text-decoration: none;
    border-radius: 16px;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    font-weight: 700;
    font-size: 1.1rem;
    border: var(--tobiracast-nav-button-border);
    backdrop-filter: blur(10px);
    background: var(--tobiracast-nav-button-bg);
    box-shadow: var(--tobiracast-nav-button-shadow);
    text-shadow: none;
    min-width: 140px;
    text-align: center;
  }

  .auth-link[hidden] {
    display: none !important;
  }

  #auth-status-loading[hidden] {
    display: none !important;
  }

  .auth-link:hover {
    background: var(--tobiracast-nav-button-bg-hover);
    border: var(--tobiracast-nav-button-border-hover);
    color: var(--tobiracast-primary-orange);
    transform: translateY(-2px) scale(1.02);
    box-shadow: var(--tobiracast-nav-button-shadow-hover);
  }

  .auth-link:focus {
    outline: 2px solid var(--tobiracast-primary-orange);
    outline-offset: 2px;
  }

  .auth-link-loading {
    color: transparent;
    pointer-events: none;
    user-select: none;
    position: relative;
    overflow: hidden;
  }

  .auth-link-loading::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        90deg,
        rgba(255, 255, 255, 0) 0%,
        rgba(255, 255, 255, 0.55) 50%,
        rgba(255, 255, 255, 0) 100%
      ),
      var(--tobiracast-nav-button-bg);
    animation: auth-link-shimmer 1.2s ease-in-out infinite;
  }

  @keyframes auth-link-shimmer {
    from {
      transform: translateX(-100%);
    }
    to {
      transform: translateX(100%);
    }
  }

  @media (max-width: 768px) {
    .auth-link {
      padding: 8px 16px;
      width: 100%;
      text-align: center;
      min-height: auto;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.85rem;
      color: var(--tobiracast-primary-orange);
      background: transparent;
      border: 2px solid transparent;
      box-shadow: none;
      border-radius: 8px;
    }

    .auth-link:hover {
      background: rgba(255, 111, 0, 0.1);
      border-color: var(--tobiracast-primary-orange);
      transform: none;
      box-shadow: none;
    }
  }
</style>

<script>
  import { onAuthStateChanged } from 'firebase/auth'
  import { getFirebaseAuth } from '../lib/firebase-client'
  import { getNativeApiBaseUrl } from '../lib/functions-url'

  const auth = getFirebaseAuth()
  const API_URL = getNativeApiBaseUrl(import.meta.env.PUBLIC_API_URL)

  // DOM要素
  const loggedOutNav = document.getElementById('logged-out-nav')
  const loggedInNav = document.getElementById('logged-in-nav')
  const authStatusLoading = document.getElementById('auth-status-loading')

  function showLoggedIn() {
    authStatusLoading.hidden = true
    loggedOutNav.hidden = true
    loggedInNav.hidden = false
  }

  function showLoggedOut() {
    authStatusLoading.hidden = true
    loggedOutNav.hidden = false
    loggedInNav.hidden = true
  }

  // 認証状態の監視
  onAuthStateChanged(auth, async (user) => {
    if (user) {
      // アカウントが完成しているか確認
      try {
        const idToken = await user.getIdToken()
        const response = await fetch(`${API_URL}/my/profile`, {
          method: 'GET',
          headers: {
            'Authorization': idToken,
            'Content-Type': 'application/json'
          }
        })
        const data = await response.json()

        if (data.status === 'success') {
          showLoggedIn()
          return
        }
      } catch {
        // API呼び出し失敗時はログインリンク表示
      }

      // アカウント未完成 → ログイン表示のまま
      showLoggedOut()
    } else {
      // 未ログイン
      showLoggedOut()
    }
  })
</script>
