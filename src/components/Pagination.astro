---
import { getPageLink } from '../lib/blog-helpers.ts'

export interface Props {
  currentPage: number
  numberOfPages: number
  tag: string
}

const { currentPage, numberOfPages, tag = '' } = Astro.props

const isFirstPage = currentPage === 1
const isLastPage = currentPage === numberOfPages

const startPage = currentPage - 2 < 1 ? 1 : currentPage - 2
const endPage =
  currentPage + 2 > numberOfPages ? numberOfPages : currentPage + 2

let pages = []
for (let i = startPage; i <= endPage; i++) {
  pages.push(i)
}
---

<div class="tobiracast-pagination">
  <a href={getPageLink(1, tag)} class={`tobiracast-pagination-item ${isFirstPage ? 'inactive' : ''}`}>&lt;&lt;</a>
  {
    pages.map((p: number) => (
      <a href={getPageLink(p, tag)} class={`tobiracast-pagination-item ${p === currentPage ? 'inactive' : ''}`}>
        {p}
      </a>
    ))
  }
  <a href={getPageLink(numberOfPages, tag)} class={`tobiracast-pagination-item ${isLastPage ? 'inactive' : ''}`}
    >&gt;&gt;</a
  >
</div>

<!-- Pagination styles now unified in tobiracast.css -->
