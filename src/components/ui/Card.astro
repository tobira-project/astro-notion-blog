---
export interface Props {
  variant?: 'default' | 'gradient' | 'article'
  class?: string
}

const { variant = 'default', class: className, ...props } = Astro.props

const variants = {
  default: 'bg-white rounded-xl shadow-tobiracast-card hover:shadow-tobiracast-hover transition-all duration-300 hover:-translate-y-1',
  gradient: 'bg-gradient-to-br from-tobiracast-blue to-tobiracast-light-blue text-white rounded-2xl shadow-tobiracast hover:shadow-tobiracast-hover',
  article: 'bg-white rounded-xl shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-2 overflow-hidden'
}

const classes = [variants[variant], className].filter(Boolean).join(' ')
---

<div class={classes} {...props}>
  <slot />
</div>