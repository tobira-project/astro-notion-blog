---
import { Icon } from 'astro-icon/components';
---

<button class="tobiracast-btn tobiracast-btn-ghost open-search-modal" type="button"><Icon name="octicon:search-24" /><span>Search</span></button>

<style>
  /* Custom search button overrides */
  .tobiracast-btn.open-search-modal {
    display: flex;
    width: 100%;
    margin-bottom: 0.5rem;
    justify-content: flex-start;
  }
  .tobiracast-btn.open-search-modal svg {
    width: 20px;
    height: 20px;
    margin-right: 0.2rem;
  }
  [astro-icon="octicon:search-24"] {
    color: var(--fg);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    function handleKeydown(event) {
      if (event.keyCode === 75 && event.metaKey) {
        // Ctrl+K or Cmd+K
        document.querySelector('.open-search-modal').click()
      }
    }

    document.addEventListener('keydown', handleKeydown)
  })
</script>
